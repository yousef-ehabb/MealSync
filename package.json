{
  "name": "mealsync",
  "version": "1.1.0",
  "description": "Automated meal booking for Al-Zahraa University dorm students",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "postinstall": "npx playwright install chromium",
    "prebuild": "node scripts/getBrowserPath.js",
    "build": "vite build && electron-builder -c electron-builder.json5",
    "build:win": "npm run prebuild && vite build && electron-builder --win -c electron-builder.json5",
    "start": "electron .",
    "test": "node --experimental-vm-modules tests/encryption.test.js"
  },
  "keywords": [
    "meal",
    "booking",
    "automation",
    "electron",
    "desktop"
  ],
  "author": "yousef-ehabb",
  "license": "ISC",
  "private": true,
  "dependencies": {
    "electron-log": "^5.3.0",
    "electron-store": "^8.1.0",
    "fs-extra": "^11.2.0",
    "lucide-react": "^0.563.0",
    "node-cron": "^3.0.3",
    "node-machine-id": "^1.1.12",
    "playwright-core": "^1.57.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.3",
    "7zip-bin": "^5.2.0",
    "app-builder-bin": "^5.0.0-alpha.12",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.2.1",
    "electron-builder": "^26.8.1",
    "shadcn": "^4.1.2",
    "vite": "^7.3.1"
  }
}
